# Financial Modeling Prep (required)
# https://site.financialmodelingprep.com/developer/docs/stable
FMP_API_KEY=

# Quote snapshot cache (ms): movers, indices, scanners, S&P batch, dashboard sector ETFs, etc.
# Default 30000 (30s). Raise if you hit FMP rate limits; lower only on plans that allow it.
# MARKET_DATA_CACHE_MS=30000

# After-hours / weekend alert testing: price alerts still need FMP quotes; VWAP/ORHL need intraday bars (mostly RTH).
# ALERTS_IGNORE_MARKET_HOURS=1

# Expose POST /api/alerts/run-check-once (auth required) outside development — optional manual engine tick.
# ALERTS_DEBUG_ENDPOINT=1

# Sectors page EOD history cache (ms). Default 300000 (5 min). Each refresh ≈ 12 EOD API calls.
# SECTOR_QUADRANT_CACHE_MS=300000

# Daily OHLCV + VWAP series per symbol (ms). Default 900000 (15 min).
# VWAP_CACHE_MS=900000
