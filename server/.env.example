# Financial Modeling Prep (required)
# https://site.financialmodelingprep.com/developer/docs/stable
FMP_API_KEY=

# JWT signing secret. REQUIRED. Must be 32+ characters in production.
# Generate one with: openssl rand -hex 32
JWT_SECRET=

# Public base URL of the deployed frontend, used in password-reset and
# email-verification links. Example: PUBLIC_BASE_URL=https://app.example.com
PUBLIC_BASE_URL=http://localhost:5173

# Directory where the SQLite database (and nightly backups) live. On Render
# point this at your mounted disk path (e.g. /var/data). Defaults to ./server/data.
# DB_DIR=/var/data

# Comma-separated list of allowed browser origins for CORS in production.
# Example: CORS_ORIGINS=https://app.example.com,https://www.example.com
# When NODE_ENV != "production" and this is unset, all origins are allowed.
# CORS_ORIGINS=

# Required in production IF you deploy the backtest microservice. Hide the
# Strategies page on the frontend with VITE_FEATURE_BACKTEST=0 if you don't.
# In development this defaults to http://127.0.0.1:8765.
# BACKTEST_SERVICE_URL=http://127.0.0.1:8765

# Email address shown on the Settings → Send feedback button (mailto link).
# VITE_FEEDBACK_EMAIL=feedback@your-domain.com

# SMTP email delivery (required for alert fire emails and daily digest)
# Works with any SMTP provider: Gmail, SendGrid, Mailgun, Postmark, etc.
# Gmail example: SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USER=you@gmail.com  SMTP_PASS=<app-password>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Optional: display name shown in the inbox. Defaults to "Vertex".
# SMTP_FROM_NAME=Vertex
# Optional: override the From address (defaults to SMTP_USER). If this already
# contains a "Name <email>" pair, SMTP_FROM_NAME is ignored.
# SMTP_FROM=Vertex Alerts <alerts@yourdomain.com>

# Quote snapshot cache (ms): movers, indices, scanners, S&P batch, dashboard sector ETFs, etc.
# Default 30000 (30s). Raise if you hit FMP rate limits; lower only on plans that allow it.
# MARKET_DATA_CACHE_MS=30000

# After-hours / weekend alert testing: all intraday alerts run 24/7 regardless of session.
# ALERTS_IGNORE_MARKET_HOURS=1

# Enable alert test routes in production: simulate-fire, test-email, run-check-once (all require auth).
# ALERTS_SIMULATION_ENABLED=1
#
# Same effect as ALERTS_DEBUG_ENDPOINT=1 (you can use either).
# ALERTS_DEBUG_ENDPOINT=1

# Sectors page EOD history cache (ms). Default 300000 (5 min). Each refresh ≈ 12 EOD API calls.
# SECTOR_QUADRANT_CACHE_MS=300000

# Daily OHLCV + VWAP series per symbol (ms). Default 900000 (15 min).
# VWAP_CACHE_MS=900000
