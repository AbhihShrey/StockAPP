# Public base URL of the API. In development the client falls back to
# http://localhost:3001 when this is unset. In production point at your API
# subdomain — e.g. VITE_API_BASE=https://api.your-domain.com
VITE_API_BASE=

# Feature flag: enable the Strategies (backtesting) page. Off by default.
# Set to 1 only after you have deployed the Python backtest microservice and
# wired BACKTEST_SERVICE_URL on the backend.
VITE_FEATURE_BACKTEST=0

# Optional: email address used by the "Send feedback" mailto link in Settings.
VITE_FEEDBACK_EMAIL=feedback@your-domain.com
